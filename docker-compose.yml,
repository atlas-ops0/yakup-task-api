version: '3.8'

services:
db:
image: postgres:15
environment:
POSTGRES_DB: taskdb
POSTGRES_USER: yakup
POSTGRES_PASSWORD: yakup123
volumes: 
-postgres_data:/var/lib/postgresql/data
ports:
-"5432:5432"

web:
build:
ports:
-"8000:8000"
depends_on:
- db
environment:
- DATABASE_URL=postgres://yakup:yakup123@db:5432/taskdb
volumes:
postgres_data:
